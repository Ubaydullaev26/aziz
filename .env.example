# ─────────────────────────────────────────────────────────────────────────
# Copy this file to .env (local dev) and fill in real values.
# In Docker Compose these are also read from .env at the repo root.
# ─────────────────────────────────────────────────────────────────────────

# Postgres connection used by Prisma. When running via `docker compose up`,
# host "db" resolves to the postgres service; for local (non-docker) dev
# against a locally running postgres, use "localhost" instead.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tourist_platform?schema=public"

# Standalone values used by docker-compose.yml to boot the postgres container.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tourist_platform

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand--base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (console.cloud.google.com -> Credentials -> OAuth Client ID)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Apple Sign In (developer.apple.com -> Certificates, Identifiers & Profiles)
# AUTH_APPLE_SECRET must be a JWT you sign with your Apple private key
# (see https://authjs.dev/getting-started/providers/apple for the script).
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# Public base URL of the deployed app (used for share links, emails, sitemaps)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Default locale/currency for the first market (Uzbekistan / Samarkand)
NEXT_PUBLIC_DEFAULT_LOCALE="ru"
NEXT_PUBLIC_DEFAULT_CURRENCY="UZS"

# Authorizes Vercel Cron to call /api/admin/import (Vercel auto-sends this
# as "Authorization: Bearer <value>" once the env var is set — nothing else
# to configure). Leave empty locally; only admins can trigger imports then.
CRON_SECRET=""
